FROM python:3.11-slim

# Установка системных зависимостей
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Установка Python зависимостей для тестирования
RUN pip install \
    requests \
    pytest \
    aiohttp \
    pyyaml

# Создание рабочей директории
WORKDIR /app

# Копирование тестов
COPY tests/ /app/tests/
COPY custom_components/ /app/custom_components/

# Установка дополнительных зависимостей для Home Assistant
RUN pip install \
    homeassistant \
    bleak \
    bleak-retry-connector

# Создание скрипта запуска тестов
COPY test_runner.py /app/test_runner.py

CMD ["python", "/app/test_runner.py"]